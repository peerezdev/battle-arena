# fuente de pricing: mock | collectorcrypt
PRICING_SOURCE=mock
# ruta del keypair ed25519 del oráculo (32 bytes semilla en hex). Se genera si no existe (solo dev).
ORACLE_KEY_PATH=oracle_key.json
# base de la API de Collector Crypt (pública, sin auth). Debe usar https:// en producción.
CC_BASE_URL=https://api.collectorcrypt.com
# TTL de caché de pricing en segundos
PRICING_CACHE_TTL=120
# límite de peticiones al endpoint /attest por IP y por minuto (0 = sin límite)
RATE_LIMIT_PER_MIN=30
# orígenes CORS permitidos, separados por coma (vacío = ninguno). Ej: https://app.example.com
CORS_ORIGINS=
