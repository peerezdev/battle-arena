DATABASE_URL=sqlite:///battlearena.db
CHAIN_SOURCE=mock          # mock | solana
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=
ELO_START=1200
ELO_K=32
SESSION_TTL=3600
CORS_ORIGINS=[]            # e.g. ["https://app.example.com","https://www.example.com"]
PRIVY_APP_ID=              # Privy App ID (público); sin él, /auth/privy/* responde 503
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json  # override opcional
# PRIVY_APP_SECRET=        # SOLO Fase B (server-signing). NUNCA commitear. Rotar el expuesto.
# Operador: wallet servidora de Privy (owned by tu quorum) que financia el GAS del escrow en
# Pack Battle/Royale. SIN estas, las batallas se ANULAN al llenarse (no se siembra el escrow → reembolso).
# Crea la wallet servidora, fondéala con SOL de devnet, y pon aquí su wallet_id + dirección Solana.
PRIVY_OPERATOR_WALLET_ID=
PRIVY_OPERATOR_ADDRESS=
# Endpoints SOLO de desarrollo/test (p.ej. POST /pack-battles/{id}/join-bot, que mete un bot
# financiado en un lobby SIN auth y mueve USDC). DEJAR EN false EN PRODUCCIÓN.
DEV_ENDPOINTS_ENABLED=false
# Anti-drenaje de retiros (el operador paga gas + renta de la ATA destino de cada withdraw):
MIN_WITHDRAW_USDC=1.0          # retiro mínimo en USDC
WITHDRAW_RATE_LIMIT=5          # nº máx. de retiros por wallet y ventana
WITHDRAW_RATE_WINDOW_S=60      # ventana del rate-limit de retiros (segundos)
# Host público de metadata/imágenes de Collector Crypt por mint (keyless). El backend hace de
# proxy (browser→backend→CC) porque ese host NO envía cabeceras CORS. Cambiar a
# https://nft.collectorcrypt.com en mainnet.
CC_NFT_BASE_URL=https://nft-dev.collectorcrypt.com
