DATABASE_URL=sqlite:///battlearena.db
CHAIN_SOURCE=mock          # mock | solana
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=
ELO_START=1200
ELO_K=32
SESSION_TTL=3600
CORS_ORIGINS=[]            # e.g. ["https://app.example.com","https://www.example.com"]
PRIVY_APP_ID=              # Privy App ID (público); sin él, /auth/privy/* responde 503
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json  # override opcional
# PRIVY_APP_SECRET=        # SOLO Fase B (server-signing). NUNCA commitear. Rotar el expuesto.
# Operador: wallet servidora de Privy (owned by tu quorum) que financia el GAS del escrow en
# Pack Battle/Royale. SIN estas, las batallas se ANULAN al llenarse (no se siembra el escrow → reembolso).
# Crea la wallet servidora, fondéala con SOL de devnet, y pon aquí su wallet_id + dirección Solana.
PRIVY_OPERATOR_WALLET_ID=
PRIVY_OPERATOR_ADDRESS=
